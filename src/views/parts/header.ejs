<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        height: 100%;
        font-family: Arial, sans-serif;
      }

      body {
        display: grid;
        grid-template-rows: auto 1fr auto;
        min-height: 100vh;
      }

      header {
        background-color: #343a40;
        color: #fff;
        padding: 16px 24px;
        text-align: center;
        font-size: 1.2rem;
      }

      main {
        padding: 0;
      }
    </style>
  </head>
  <body>
    <header></header>
    <main>
  </body>
</html>
